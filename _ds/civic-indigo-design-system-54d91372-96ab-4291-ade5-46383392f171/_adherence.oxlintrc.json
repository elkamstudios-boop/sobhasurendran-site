{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/election/**",
              "components/media/**",
              "components/profile/**",
              "components/typography/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Montserrat|Mulish))/i]",
        "message": "Font not provided by the design system. Available: Montserrat, Mulish."
      },
      {
        "selector": "JSXOpeningElement[name.name='AchievementChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|align|key|ref|className|style|children)$/]",
        "message": "<AchievementChip> doesn't accept that prop. Declared props: children, tone, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='AchievementChip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:indigo|ink|gold|tint)$/]",
        "message": "<AchievementChip> tone must be one of 'indigo' | 'ink' | 'gold' | 'tint'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AchievementChip'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<AchievementChip> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|children|onDark|key|ref|className|style|children)$/]",
        "message": "<ContactItem> doesn't accept that prop. Declared props: icon, children, onDark."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactItem'] > JSXAttribute[name.name='icon'] > Literal[value!=/^(?:pin|phone|social|mail)$/]",
        "message": "<ContactItem> icon must be one of 'pin' | 'phone' | 'social' | 'mail'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ElectionRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:year|name|votes|highlight|key|ref|className|style|children)$/]",
        "message": "<ElectionRow> doesn't accept that prop. Declared props: year, name, votes, highlight."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|onDark|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, onDark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PhotoFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|ratio|accent|radius|style|key|ref|className|style|children)$/]",
        "message": "<PhotoFrame> doesn't accept that prop. Declared props: src, alt, ratio, accent, radius, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PhotoFrame'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:none|indigo|gold)$/]",
        "message": "<PhotoFrame> accent must be one of 'none' | 'indigo' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PhotoFrame'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<PhotoFrame> radius must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|children|align|onDark|size|key|ref|className|style|children)$/]",
        "message": "<SectionHeading> doesn't accept that prop. Declared props: eyebrow, children, align, onDark, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<SectionHeading> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<SectionHeading> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|caption|size|onDark|key|ref|className|style|children)$/]",
        "message": "<StatBadge> doesn't accept that prop. Declared props: value, caption, size, onDark."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<StatBadge> size must be one of 'sm' | 'md' | 'lg'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
